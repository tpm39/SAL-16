    </comp>
    <comp lib="6" loc="(1378,211)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="BKGRD button is set Hi. "/>
    </comp>
    <comp lib="6" loc="(1421,290)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="then set up IN_x and press ENTER_x."/>
    </comp>
    <comp lib="6" loc="(1442,331)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="10. Press the RESET button to re-run the program."/>
    </comp>
    <comp lib="6" loc="(1456,232)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="6. Press the RESET button to initilaise the computer."/>
    </comp>
    <comp lib="6" loc="(1460,132)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="3. Ensure that TimmiOS.mc is in the computer's ROM."/>
    </comp>
    <comp lib="6" loc="(1460,152)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="4. Ensure that the program is in the computer's RAM."/>
    </comp>
    <comp lib="6" loc="(1460,172)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="5. If a Graphics Background has been loaded into the"/>
    </comp>
    <comp lib="6" loc="(1462,58)" name="Text">
      <a name="font" val="SansSerif bold 18"/>
      <a name="text" val="NOTES"/>
    </comp>
    <comp lib="6" loc="(1464,311)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="9. The Program has completed when END turns green."/>
    </comp>
    <comp lib="6" loc="(1470,112)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="2. Ensure that Microcode.uc is in the control unit's ROM."/>
    </comp>
    <comp lib="6" loc="(1474,409)" name="Text">
      <a name="font" val="SansSerif bold 18"/>
      <a name="text" val="COMPUTER"/>
    </comp>
    <comp lib="6" loc="(1480,191)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="Graphics Unit ROM, and is to be used, ensure that the "/>
    </comp>
    <comp lib="6" loc="(1480,271)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="8. If any IN_x input is required the WAIT_x led will turn red,"/>
    </comp>
    <comp lib="6" loc="(1480,92)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="1. Ensure that MicrocodeLUT.uc is in the control unit's LUT."/>
    </comp>
    <comp lib="6" loc="(1517,251)" name="Text">
      <a name="font" val="SansSerif plain 14"/>
      <a name="text" val="7. Set 'Auto-Tick Frequency' to 8MHz, then select 'Auto-Tick Enabled'."/>
    </comp>
